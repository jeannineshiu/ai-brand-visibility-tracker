OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
GCP_PROJECT_ID=your-project-id
BIGQUERY_DATASET=brand_tracker
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Required to call POST /retrain — set a strong random string
RETRAIN_API_KEY=

# Slack alerting (optional) — fires when brand visibility drops
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
VISIBILITY_ALERT_THRESHOLD=15.0   # alert if visibility % falls below this
VISIBILITY_DROP_ALERT=5.0          # alert if visibility drops this many points vs last run
